---
interface NavLink {
  id: string;
  label: string;
  href: string;
}

interface Props {
  links: NavLink[];
}

const { links } = Astro.props;
---

<header role="banner">
  <nav
    aria-label="Main navigation"
    class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-12 py-4"
    style="background: color-mix(in srgb, var(--color-surface-variant) 60%, transparent); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);"
  >
    <!-- Logo / wordmark -->
    <a
      href="#hero"
      class="font-display font-bold text-lg tracking-tight text-on-surface"
      aria-label="Daniel Gualdron — home"
    >
      DG
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0" role="list">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-on-surface-variant hover:text-on-surface transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Open navigation menu"
      class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
    >
      <span class="block w-6 h-px bg-on-surface-variant transition-all duration-300" aria-hidden="true"></span>
      <span class="block w-6 h-px bg-on-surface-variant transition-all duration-300" aria-hidden="true"></span>
      <span class="block w-4 h-px bg-on-surface-variant transition-all duration-300" aria-hidden="true"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    role="dialog"
    aria-label="Navigation menu"
    aria-modal="true"
    hidden
    class="fixed inset-0 z-40 pt-20 px-6 md:hidden flex flex-col"
    style="background: color-mix(in srgb, var(--color-surface) 95%, transparent); backdrop-filter: blur(24px);"
  >
    <ul class="flex flex-col gap-6 list-none m-0 p-0" role="list">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-display text-2xl font-light text-on-surface-variant hover:text-on-surface transition-colors duration-300 mobile-nav-link block"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    function closeMenu() {
      toggle.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.hidden = isOpen;
    });

    menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hidden) {
        closeMenu();
        toggle.focus();
      }
    });
  }
</script>

---
interface Props {
  id: string;
  title: string;
  category: string;
  youtubeId: string;
  poster?: string;
  meta: string;
  hidden?: boolean;
}

const {
  id,
  title,
  category,
  youtubeId,
  poster,
  meta,
  hidden = false,
} = Astro.props;

// Fallback chain: explicit prop → YouTube thumbnail → local placeholder
const resolvedPoster =
  poster ||
  (youtubeId ? `https://img.youtube.com/vi/${youtubeId}/hqdefault.jpg` : '') ||
  '/posters/placeholder.svg';
---

<article
  class='video-card scroll-reveal relative rounded-lg overflow-hidden cursor-pointer group'
  data-id={id}
  data-category={category}
  data-hidden={hidden ? 'true' : 'false'}
  data-youtube-id={youtubeId}
  data-title={title}
  data-meta={meta}
  style='background: var(--color-surface-container-lowest);'
  aria-label={`${title} — ${category}`}
  role='button'
  tabindex='0'>
  <!-- Skeleton placeholder -->
  <div
    class='skeleton absolute inset-0 z-10 rounded-lg transition-opacity duration-500'
    data-skeleton
    aria-hidden='true'>
  </div>

  <!-- Thumbnail (static image — YouTube doesn't support inline silent preview) -->
  <img
    class='w-full aspect-video object-cover block'
    src={resolvedPoster}
    alt={title}
    loading='lazy'
    data-thumbnail
  />

  <!-- Play icon overlay (fades in on hover via CSS) -->
  <div
    class='video-card__play-icon absolute inset-0 z-15 flex items-center justify-center pointer-events-none'
    aria-hidden='true'>
    <div
      class='w-14 h-14 rounded-full flex items-center justify-center'
      style='background: rgba(0,0,0,0.42); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);'>
      <svg
        width='20'
        height='20'
        viewBox='0 0 20 20'
        fill='none'
        aria-hidden='true'
        style='color: var(--color-primary);'>
        <path d='M6 4.5l11 5.5-11 5.5V4.5z' fill='currentColor'></path>
      </svg>
    </div>
  </div>

  <!-- Overlay info -->
  <div
    class='absolute bottom-0 left-0 right-0 p-4 z-20'
    style='background: linear-gradient(to top, color-mix(in srgb, var(--color-surface-container-lowest) 95%, transparent) 0%, color-mix(in srgb, var(--color-surface-container-lowest) 60%, transparent) 50%, transparent 100%);'>
    <p
      class='text-xs uppercase tracking-widest mb-1'
      style='color: var(--color-primary); letter-spacing: 0.15em;'>
      {category}
    </p>
    <h3 class='font-display text-base font-semibold text-on-surface leading-snug'>
      {title}
    </h3>
    <p class='text-xs mt-1 uppercase tracking-widest' style='color: var(--color-on-surface-variant); letter-spacing: 0.15em;'>
      {meta}
    </p>
  </div>
</article>

<script>
  document.querySelectorAll('.video-card').forEach((card) => {
    if (!(card instanceof HTMLElement)) return;

    const thumbnailEl = card.querySelector<HTMLImageElement>('[data-thumbnail]');
    const skeleton = card.querySelector<HTMLElement>('[data-skeleton]');

    const hideSkeleton = () => {
      if (skeleton instanceof HTMLElement) skeleton.style.opacity = '0';
    };

    if (!thumbnailEl) {
      hideSkeleton();
      return;
    }

    // Hide skeleton once thumbnail loads
    if (thumbnailEl.complete) {
      hideSkeleton();
    } else {
      thumbnailEl.addEventListener('load', hideSkeleton);
      thumbnailEl.addEventListener('error', hideSkeleton);
    }

    // Click or keyboard → open modal
    const openModal = () => {
      const youtubeId = card.dataset.youtubeId;
      if (!youtubeId) return;
      document.dispatchEvent(
        new CustomEvent('video:open', {
          detail: {
            youtubeId,
            title: card.dataset.title ?? '',
            meta: card.dataset.meta ?? '',
            category: card.dataset.category ?? '',
            rect: card.getBoundingClientRect(),
          },
        }),
      );
    };

    card.addEventListener('click', openModal);

    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal();
      }
    });
  });
</script>

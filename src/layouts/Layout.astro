---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Daniel Gualdron — Director of Photography',
  description = 'Daniel Gualdron — Director of Photography based in Atlanta. Commercial, narrative, and branded content cinematography. Seven years of crafting cinematic stories.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Daniel Gualdron" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Manrope:wght@300;400;600;700;800&display=swap"
      media="print" onload="this.media='all'"
      rel="stylesheet"
    />

  </head>
  <body class="min-h-screen overflow-x-hidden">
    <!-- Scroll Progress Indicator -->
    <div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-primary z-[999] origin-left scale-x-0 transition-transform duration-100 ease-out"></div>
    
    <slot />

    <script>
      // Scroll Progress Indicator
      const updateScrollProgress = () => {
        const docElement = document.documentElement;
        const scrollTotal = docElement.scrollHeight - docElement.clientHeight;
        const scrollProgress = scrollTotal > 0 ? (docElement.scrollTop / scrollTotal) : 0;
        const progressBar = document.getElementById('scroll-progress');
        if (progressBar) {
          progressBar.style.transform = `scaleX(${scrollProgress})`;
        }
      };

      // Intersection Observer for Scroll Reveals
      const setupScrollReveals = () => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('scroll-reveal-active');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            root: null,
            rootMargin: '0px',
            threshold: 0.1,
          }
        );

        document.querySelectorAll('.scroll-reveal').forEach((el) => {
          observer.observe(el);
        });
      };

      window.addEventListener('scroll', updateScrollProgress, { passive: true });
      updateScrollProgress(); // Initial call
      
      // Setup reveals after preloader finishes or right away
      document.addEventListener('DOMContentLoaded', setupScrollReveals);
    </script>
  </body>
</html>

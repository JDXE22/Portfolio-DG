---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/Button.astro';
import TrustedBy from '../components/TrustedBy.astro';
import VideoCard from '../components/VideoCard.astro';

const isReelReady = false;

const navLinks = [
  { id: 'hero',           label: 'Home',           href: '#hero' },
  { id: 'about',          label: 'About',          href: '#about' },
  { id: 'cinematography', label: 'Cinematography', href: '#cinematography' },
  { id: 'contact',        label: 'Contact',        href: '#contact' },
];

const logos = [
  { name: 'HoneyBaked', src: '/logos/HoneyBaked.svg' },
  { name: 'Etihad',     src: '/logos/Etihad.svg' },
  { name: 'Allstate',   src: '/logos/Allstate.svg',  width: 180 },
  { name: 'Kroger',     src: '/logos/Kroger.svg' },
  { name: 'Georgia',    src: '/logos/Georgia.svg',   width: 200 },
  { name: 'OldSpice',   src: '/logos/OldSpice.svg' },
  { name: 'Swiffer',    src: '/logos/Swiffer.svg' },
  { name: 'Tide',       src: '/logos/Tide.svg' },
  { name: 'PndG',       src: '/logos/PndG.svg' },
];

const categories = ['All', 'Commercial', 'Interview', 'Art', 'Social', 'Narrative'];

const videos = [
  {
    id: 'v1',
    title: '8th Insignia',
    category: 'Art',
    playbackId: 'Zuf93jaGQ00Wot7PQKK010202IgsOnLiNkFfDVlqYhIWOaw',
    meta: '1080p • ANAMORPHIC • 2026',
  },
  {
    id: 'v2',
    title: 'STUDIO SESSION FINAL V2',
    category: 'Art',
    playbackId: 'V5l6q2400GsVt2TAtU00gKQEJIRVip02iy8rSFOC00maKJ8',
    meta: '1080p • SPHERICAL • 2024',
  },
  {
    id: 'v3',
    title: 'Resurgens Orthopedics: Adonis',
    category: 'Commercial',
    playbackId: 'swXS5EuMOFje1FAerjKSjAm301HVtY01cYxLGrSODyF8s',
    meta: '1080p • ANAMORPHIC • 2023',
  },
  {
    id: 'v4',
    title: 'Resurgens Orthopedics: Loren',
    category: 'Commercial',
    playbackId: 'zUCj35GQ1kkmnbaLwNfS7pEZyGmqo9NiDdiJVWJQh28',
    meta: '1080p • SPHERICAL • 2024',
  },
  {
    id: 'v5',
    title: 'ESnH',
    category: 'Interview',
    playbackId: '02Y4mVaFw52iGqinjY0102sTnELxMAmZQNv4Ol3yScSlUE',
    meta: '1080p • ANAMORPHIC • 2023',
  },
  {
    id: 'v6',
    title: 'Resurgens Orthopedics: Spine Center',
    category: 'Interview',
    playbackId: 'voTUPIIVO501IqX9rTOh7g01HYgU1YAil2q468Vsn4o3Y',
    meta: '1080p • SPHERICAL • 2024',
  },

  {
    id: 'v7',
    title: 'Atlanta Fanzone',
    category: 'Social',
    playbackId: '2V0000Zo88ubbf8QSD67Gzjane01w7UrJOvDs8tWVezvco',
    meta: '1080p • ANAMORPHIC • 2026',
  },
  {
    id: 'v8',
    title: 'Camp Southern Ground: Land of Transformation',
    category: 'Narrative',
    playbackId: 'oV01KEu7T9hUXFQH85ykBk6AyV301uvs9TqM81lWm34mM',
    meta: '1080p • SPHERICAL • 2026',
  },

  {
    id: 'v9',
    title: 'Georgia Heart Video Campaign',
    category: 'Narrative',
    playbackId: 'iWy7UJZdM8aWl1MAEFNJoMIKF00RvDQXUfUpniZMrgus',
    meta: '1080p • ANAMORPHIC • 2026',
  },

  {
    id: 'v10',
    title: 'SPM',
    category: 'Social',
    playbackId: 'NIO97BZzvcJ6t51PRAA6AetnBxQGZHFRU01puxL9BBfI',
    meta: '1080p • ANAMORPHIC • 2026',
  }
];

const INITIAL_VISIBLE = 4;
---

<Layout>
  <!-- ── Preloader ──────────────────────────────── -->
  <div
    id="preloader"
    aria-hidden="true"
    class="fixed inset-0 z-100 flex items-center justify-center"
    style="background: var(--color-surface-container-lowest);"
  >
    <h1
      class="font-display font-bold text-on-surface select-none"
      style="font-size: clamp(3rem, 10vw, 7rem); letter-spacing: -0.04em;"
    >
      Daniel Gualdron
    </h1>
  </div>

  <!-- ── Navigation ────────────────────────────── -->
  <Navbar links={navLinks} />

  <div id="page-wrap">
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────── -->
    <section
      id="hero"
      aria-label="Hero"
      class="relative min-h-screen flex flex-col justify-end pb-20 px-6 md:px-12 pt-32"
      style="background: var(--color-surface);"
    >
      <!-- Background portrait -->
      <img
        src="https://res.cloudinary.com/dqyaxyvxz/image/upload/f_auto,q_auto,w_1920/v1779308364/20250720-DaniShinobi-9_skz4wd.jpg"
        alt=""
        aria-hidden="true"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 w-full h-full object-cover object-center"
        style="z-index: 0;"
      />
      <!-- Dark gradient overlay — keeps text legible -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="z-index: 1; background: linear-gradient(to top, var(--color-surface) 20%, color-mix(in srgb, var(--color-surface) 50%, transparent) 55%, color-mix(in srgb, var(--color-surface) 20%, transparent) 100%);"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-4xl" style="z-index: 2;">
        <p
          class="text-xs uppercase tracking-widest mb-6"
          style="color: var(--color-primary); letter-spacing: 0.15em;"
        >
          Director of Photography
        </p>
        <h2
          class="font-display font-bold text-on-surface mb-8 leading-none"
          style="font-size: clamp(2.5rem, 7vw, 5.5rem); letter-spacing: -0.04em;"
        >
          Framing stories<br />worth watching.
        </h2>
        <div class="flex items-center gap-4 flex-wrap">
          {isReelReady ? (
            <Button variant="primary" href="#reel" label="Watch the reel">
              Watch the Reel
            </Button>
          ) : (
            <Button variant="primary" disabled label="Reel coming soon">
              Reel Coming Soon
            </Button>
          )}
          <Button variant="secondary" href="#cinematography">
            View Work
          </Button>
        </div>

        <!-- Scroll cue -->
        <div class="flex items-center gap-3 mt-6" aria-hidden="true">
          <div
            class="w-8 h-px"
            style="background: var(--color-primary);"
          ></div>
          <span class="text-xs uppercase tracking-widest" style="color: var(--color-outline-variant); letter-spacing: 0.15em;">
            Scroll to explore
          </span>
          <span
            class="text-on-surface-variant animate-bounce"
            style="animation-duration: 2s;"
          >↓</span>
        </div>
      </div>

      <!-- Trusted By -->
      <div class="relative mt-20" style="z-index: 2; border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 15%, transparent); padding-top: 2rem;">
        <p
          class="text-xs uppercase tracking-widest mb-6 px-0"
          style="color: var(--color-outline-variant); letter-spacing: 0.15em;"
        >
          Trusted by
        </p>
        <TrustedBy logos={logos} />
      </div>
    </section>

    <!-- ── About ─────────────────────────────────── -->
    <section
      id="about"
      aria-label="About"
      class="px-6 md:px-12 py-24 md:py-32"
      style="background: var(--color-surface-container-low);"
    >
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16 items-center">

        <!-- Bio -->
        <div>
          <p
            class="text-xs uppercase tracking-widest mb-6"
            style="color: var(--color-primary); letter-spacing: 0.15em;"
          >
            About
          </p>
          <!-- Left accent bar + heading -->
          <div class="flex gap-4 items-stretch mb-6">
            <span class="about-accent-bar" aria-hidden="true"></span>
            <h2
              class="font-display font-bold text-on-surface leading-tight"
              style="font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: -0.03em;"
            >
              Every frame is<br />a decision.
            </h2>
          </div>
          <p class="text-base leading-relaxed mb-4" style="color: var(--color-on-surface-variant);">
            I believe stories aren’t just seen, they’re felt. As a filmmaker, editor, and creative originally from Colombia, based in Atlanta, I bridge the gap between imagination and high end production. For over seven years, I’ve specialized in crafting commercial, corporate, and branded content that blends cinematic atmosphere with authentic storytelling.
          </p>
          <p class="text-base leading-relaxed mb-8" style="color: var(--color-on-surface-variant);">
From concept development to the final edit, I immerse myself in every step of the process, cinematography, direction, and post production, turning bold ideas into striking visuals that resonate, inspire, and leave a lasting impact.
          </p>
        </div>

        <!-- Portrait -->
        <div class="relative">
          <div
            class="relative rounded-lg overflow-hidden"
            style="background: var(--color-surface-container-high);"
          >
            <!-- Inner glow overlay -->
            <div
              class="absolute inset-0 z-10 rounded-lg pointer-events-none"
              style="box-shadow: inset 0 0 40px color-mix(in srgb, var(--color-surface-container-lowest) 30%, transparent);"
              aria-hidden="true"
            ></div>
            <img
              src="https://res.cloudinary.com/dqyaxyvxz/image/upload/f_auto,q_auto,w_900/v1779308186/ssf_Green_Rose-5_vcyvzk.heic"
              alt="Daniel Gualdron, Director of Photography"
              width="900"
              height="1125"
              loading="lazy"
              class="portrait-img w-full object-cover block"
              style="aspect-ratio: 4/5;"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ── Cinematography ─────────────────────────── -->
    <section
      id="cinematography"
      aria-label="Cinematography work"
      class="px-6 md:px-12 py-24 md:py-32"
      style="background: var(--color-surface);"
    >
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
          <div>
            <p
              class="text-xs uppercase tracking-widest mb-3"
              style="color: var(--color-primary); letter-spacing: 0.15em;"
            >
              Work
            </p>
            <h2
              class="font-display font-bold text-on-surface leading-tight"
              style="font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em;"
            >
              Cinematography
            </h2>
          </div>

          <!-- Category filters -->
          <div
            role="group"
            aria-label="Filter by category"
            class="flex flex-wrap gap-2"
            id="filter-group"
          >
            {categories.map((cat, i) => (
              <button
                type="button"
                class={`filter-pill text-xs uppercase tracking-widest px-4 py-2 rounded-full transition-all duration-300 cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary ${i === 0 ? 'active' : ''}`}
                data-filter={cat}
                aria-pressed={i === 0 ? 'true' : 'false'}
                style={i !== 0 ? `border: 1px solid color-mix(in srgb, var(--color-outline-variant) 20%, transparent); color: var(--color-on-surface-variant);` : ''}
              >
                {cat}
              </button>
            ))}
          </div>
        </div>

        <!-- Video grid -->
        <div
          id="video-grid"
          class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6"
          role="list"
          aria-label="Video portfolio"
        >
          {videos.map((v, i) => (
            <div role="listitem">
              <VideoCard
                id={v.id}
                title={v.title}
                category={v.category}
                playbackId={v.playbackId}
                meta={v.meta}
                hidden={i >= INITIAL_VISIBLE}
              />
            </div>
          ))}
        </div>

        <!-- View All -->
        {videos.length > INITIAL_VISIBLE && (
          <div class="mt-10 text-center">
            <Button
              variant="secondary"
              id="view-all-btn"
              label="Show all cinematography work"
            >
              View All Work
            </Button>
          </div>
        )}
      </div>
    </section>

    <!-- ── Contact ────────────────────────────────── -->
    <section
      id="contact"
      aria-label="Contact"
      class="relative px-6 md:px-12 py-24 md:py-32 overflow-hidden"
      style="background: var(--color-surface-container-lowest);"
    >
      <!-- Ambient glow -->
      <div class="contact-glow" aria-hidden="true"></div>

      <div class="relative z-10 max-w-2xl mx-auto text-center">
        <p
          class="text-xs uppercase tracking-widest mb-6"
          style="color: var(--color-primary); letter-spacing: 0.15em;"
        >
          Get in touch
        </p>
        <h2
          class="font-display font-bold text-on-surface mb-6 leading-tight"
          style="font-size: clamp(2rem, 5vw, 3.5rem); letter-spacing: -0.04em;"
        >
          Let's make<br />something great.
        </h2>
        <p class="text-base leading-relaxed mb-10" style="color: var(--color-on-surface-variant);">
          Available for commercial, narrative, and documentary projects.
          Reach out to discuss your vision.
        </p>

        <!-- Email CTA -->
        <Button
          variant="primary"
          href="mailto:gualdrondaniel@gmail.com"
          label="Email Daniel Gualdron"
        >
          Email Me
        </Button>

        <!-- Social links -->
        <div class="flex items-center justify-center gap-8 mt-12">
          <a
            href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Daniel Gualdron on Instagram (opens in new tab)"
            class="flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          >
            <!-- Instagram icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
            Instagram
          </a>
          <div class="w-px h-4" style="background: var(--color-outline-variant);" aria-hidden="true"></div>
          <a
            href="https://www.linkedin.com/in/daniel-gualdron-858063271"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Daniel Gualdron on LinkedIn (opens in new tab)"
            class="flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          >
            <!-- LinkedIn icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- ── Footer ─────────────────────────────────── -->
  <footer
    id="site-footer"
    role="contentinfo"
    class="px-6 md:px-12 py-8 flex flex-col md:flex-row items-center justify-between gap-4"
    style="background: var(--color-surface-container-lowest); border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 10%, transparent);"
  >
    <p class="text-xs" style="color: var(--color-outline-variant);">
      &copy; {new Date().getFullYear()} Daniel Gualdron. All rights reserved.
    </p>
    <p class="text-xs" style="color: var(--color-outline-variant);">
      Director of Photography
    </p>
  </footer>
  </div>{/* #page-wrap */}

  <!-- ── Video Modal ──────────────────────────── -->
  <div
    id="video-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Video player"
    class="fixed inset-0 z-80 hidden"
  >
    <!-- Backdrop -->
    <div
      id="modal-backdrop"
      class="absolute inset-0"
      style="background: rgba(4,4,4,0.9); opacity: 0;"
    ></div>

    <!-- Panel (this is what FLIP-animates) -->
    <div
      id="modal-inner"
      class="absolute rounded-lg overflow-hidden"
      style="top: 50%; left: 50%; width: min(90vw, 1100px); transform: translate(-50%, -50%); transform-origin: center center; opacity: 0;"
    >
      <!-- Close button -->
      <button
        id="modal-close"
        aria-label="Close video"
        class="absolute top-3 right-3 z-10 w-9 h-9 flex items-center justify-center rounded-full cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        style="background: rgba(0,0,0,0.55); backdrop-filter: blur(6px); color: #fff; border: 1px solid rgba(255,255,255,0.12);"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>

      <!-- Mux player (controls visible by default) -->
      <mux-player
        id="modal-player"
        class="w-full block"
        stream-type="on-demand"
        playsinline
        preload="none"
        style="aspect-ratio: 16/9; display: block; --media-object-fit: contain;"
      ></mux-player>

      <!-- Info bar -->
      <div
        class="px-5 py-4 flex items-baseline justify-between gap-4"
        style="background: var(--color-surface-container-lowest);"
      >
        <div>
          <p
            id="modal-category"
            class="text-xs uppercase tracking-widest mb-0.5"
            style="color: var(--color-primary); letter-spacing: 0.15em;"
          ></p>
          <h3
            id="modal-title"
            class="font-display text-base font-semibold text-on-surface leading-snug"
          ></h3>
        </div>
        <p
          id="modal-meta"
          class="text-xs shrink-0"
          style="color: var(--color-on-surface-variant);"
        ></p>
      </div>
    </div>
  </div>
</Layout>

<!-- ── Global modal styles ───────────────────────── -->
<style is:global>
  #page-wrap {
    transition: filter 0.35s ease;
  }
  #page-wrap.modal-open {
    filter: blur(5px) brightness(0.35);
    pointer-events: none;
    user-select: none;
  }
</style>

<!-- ── Scripts ───────────────────────────────────── -->
<script>
  const preloader  = document.getElementById('preloader');
  const pageWrap   = document.getElementById('page-wrap');
  const siteHeader = document.querySelector('body > header');

  if (preloader) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nameEl = preloader.querySelector('h1');

    if (nameEl) {
      if (prefersReduced) {
        nameEl.animate(
          [{ opacity: 0 }, { opacity: 1 }],
          { duration: 800, easing: 'ease-out', fill: 'forwards' }
        );
      } else {
        nameEl.animate(
          [
            { opacity: 0, transform: 'translateY(80px) scale(0.85)' },
            { opacity: 1, transform: 'translateY(0px)  scale(1)'    },
          ],
          { duration: 4000, easing: 'ease-in-out', fill: 'forwards' }
        );
      }
    }

    const holdDelay = prefersReduced ? 1000 : 5500;

    setTimeout(() => {
      preloader.classList.add('done');

      setTimeout(() => {
        if (pageWrap)   pageWrap.classList.add('revealed');
        if (siteHeader) siteHeader.classList.add('revealed');
      }, prefersReduced ? 0 : 900);

      preloader.addEventListener('animationend', (e) => {
        if (e.animationName !== 'fadeOut') return;
        preloader.remove();
      }, { once: true });
    }, holdDelay);
  }

  const filterGroup   = document.getElementById('filter-group');
  const videoGrid     = document.getElementById('video-grid');
  const viewAllBtn    = document.getElementById('view-all-btn');
  const INITIAL_VISIBLE_COUNT = 4;
  const INACTIVE_PILL_STYLE   = 'border: 1px solid color-mix(in srgb, var(--color-outline-variant) 20%, transparent); color: var(--color-on-surface-variant);';
  const FOCUSABLE_SELECTOR    = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

  let expanded = false;

  function cardMatchesFilter(card: HTMLElement, filter: string): boolean {
    return filter === 'All' || card.dataset.category === filter;
  }

  function getActiveFilter(): string {
    const activepill = filterGroup?.querySelector('.filter-pill.active');
    return (activepill instanceof HTMLElement ? activepill.dataset.filter : null) ?? 'All';
  }

  function collapseGrid(filter: string) {
    if (!videoGrid) return;
    let visibleCount = 0;
    videoGrid.querySelectorAll('.video-card').forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      if (cardMatchesFilter(card, filter)) {
        visibleCount++;
        card.dataset.hidden = visibleCount > INITIAL_VISIBLE_COUNT ? 'true' : 'false';
      }
    });
  }

  function syncViewAllBtn(filter: string) {
    if (!viewAllBtn || !videoGrid) return;
    let matchCount = 0;
    videoGrid.querySelectorAll('.video-card').forEach((card) => {
      if (card instanceof HTMLElement && cardMatchesFilter(card, filter)) matchCount++;
    });
    viewAllBtn.hidden = matchCount <= INITIAL_VISIBLE_COUNT;
    viewAllBtn.textContent = 'View All Work';
    viewAllBtn.setAttribute('aria-label', 'Show all cinematography work');
  }

  if (filterGroup && videoGrid) {
    filterGroup.addEventListener('click', (e) => {
      if (!(e.target instanceof HTMLElement)) return;
      const clickedPill = e.target.closest('.filter-pill');
      if (!(clickedPill instanceof HTMLElement)) return;

      const filter = clickedPill.dataset.filter ?? 'All';

      filterGroup.querySelectorAll('.filter-pill').forEach((pill) => {
        const isActive = pill === clickedPill;
        pill.classList.toggle('active', isActive);
        pill.setAttribute('aria-pressed', String(isActive));
        if (pill instanceof HTMLElement) {
          pill.style.cssText = isActive ? '' : INACTIVE_PILL_STYLE;
        }
      });

      videoGrid.querySelectorAll('.video-card').forEach((card) => {
        if (!(card instanceof HTMLElement)) return;
        card.dataset.hidden = cardMatchesFilter(card, filter) ? 'false' : 'true';
      });

      expanded = false;
      collapseGrid(filter);
      syncViewAllBtn(filter);
    });
  }

  // View All / Show Less toggle
  if (viewAllBtn && videoGrid) {
    viewAllBtn.addEventListener('click', () => {
      const filter = getActiveFilter();
      if (!expanded) {
        videoGrid.querySelectorAll('.video-card').forEach((card) => {
          if (card instanceof HTMLElement && cardMatchesFilter(card, filter)) {
            card.dataset.hidden = 'false';
          }
        });
        viewAllBtn.textContent = 'Show Less';
        viewAllBtn.setAttribute('aria-label', 'Show fewer videos');
        expanded = true;
      } else {
        collapseGrid(filter);
        viewAllBtn.textContent = 'View All Work';
        viewAllBtn.setAttribute('aria-label', 'Show all cinematography work');
        expanded = false;
      }
    });
  }

  // ── Video Modal ──────────────────────────────────────────────────────────
  const modal        = document.getElementById('video-modal');
  const backdrop     = document.getElementById('modal-backdrop');
  const modalInner   = document.getElementById('modal-inner');
  const modalPlayer  = document.getElementById('modal-player');
  const modalClose   = document.getElementById('modal-close');
  const modalTitleEl = document.getElementById('modal-title');
  const modalMetaEl  = document.getElementById('modal-meta');
  const modalCatEl   = document.getElementById('modal-category');

  if (modal && backdrop && modalInner && modalPlayer && modalClose) {
    const player = modalPlayer as HTMLElement & { pause?: () => void };

    let isOpen = false;
    let lastFocused: Element | null = null;

    function openModal(detail: { playbackId: string; title: string; meta: string; category: string; rect: DOMRect }) {
      const { playbackId, title, meta, category, rect } = detail;
      if (!playbackId || isOpen) return;
      isOpen = true;
      lastFocused = document.activeElement;

      if (modalTitleEl) modalTitleEl.textContent = title;
      if (modalMetaEl)  modalMetaEl.textContent  = meta;
      if (modalCatEl)   modalCatEl.textContent   = category;
      player.setAttribute('playback-id', playbackId);

      modal.classList.remove('hidden');
      modalInner.style.transition = 'none';
      modalInner.style.transform  = 'translate(-50%, -50%)';
      modalInner.style.opacity    = '0';
      backdrop.style.transition   = 'none';
      backdrop.style.opacity      = '0';
      modal.style.pointerEvents   = 'none';

      void modalInner.offsetHeight;
      const innerRect = modalInner.getBoundingClientRect();

      const scaleX = rect.width  / innerRect.width;
      const scaleY = rect.height / innerRect.height;
      const tx     = (rect.left + rect.width  / 2) - (window.innerWidth  / 2);
      const ty     = (rect.top  + rect.height / 2) - (window.innerHeight / 2);

      modalInner.style.transform = `translate(calc(-50% + ${tx}px), calc(-50% + ${ty}px)) scale(${scaleX}, ${scaleY})`;
      modalInner.style.opacity   = '1';

      document.body.style.overflow = 'hidden';
      pageWrap?.classList.add('modal-open');
      pageWrap?.setAttribute('inert', '');

      void modalInner.offsetHeight;

      requestAnimationFrame(() => {
        modalInner.style.transition = 'transform 0.46s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease';
        modalInner.style.transform  = 'translate(-50%, -50%)';
        backdrop.style.transition   = 'opacity 0.35s ease';
        backdrop.style.opacity      = '1';
        modal.style.pointerEvents   = 'auto';
      });

      setTimeout(() => modalClose.focus(), 480);
    }

    function closeModal() {
      if (!isOpen) return;
      isOpen = false;
      modal.style.pointerEvents = 'none';

      try { player.pause?.(); } catch (_) {}

      modalInner.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease';
      modalInner.style.transform  = 'translate(-50%, -50%) scale(0.94)';
      modalInner.style.opacity    = '0';
      backdrop.style.transition   = 'opacity 0.28s ease';
      backdrop.style.opacity      = '0';

      setTimeout(() => {
        modal.classList.add('hidden');
        player.removeAttribute('playback-id');
        document.body.style.overflow = '';
        pageWrap?.classList.remove('modal-open');
        pageWrap?.removeAttribute('inert');
        if (lastFocused instanceof HTMLElement) lastFocused.focus();
      }, 320);
    }

    function trapFocus(e: KeyboardEvent) {
      const focusableElements = Array.from(
        modal.querySelectorAll<HTMLElement>(FOCUSABLE_SELECTOR)
      ).filter((el) => !el.closest('[hidden]') && el.offsetParent !== null);

      if (focusableElements.length === 0) { e.preventDefault(); return; }

      const firstFocusable = focusableElements[0];
      const lastFocusable  = focusableElements[focusableElements.length - 1];

      if (e.shiftKey) {
        if (document.activeElement === firstFocusable) { e.preventDefault(); lastFocusable.focus(); }
      } else {
        if (document.activeElement === lastFocusable)  { e.preventDefault(); firstFocusable.focus(); }
      }
    }

    document.addEventListener('video:open', (e) => {
      openModal((e as CustomEvent<{ playbackId: string; title: string; meta: string; category: string; rect: DOMRect }>).detail);
    });

    modalClose.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (!modalInner.contains(e.target as Node | null)) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') { closeModal(); return; }
      if (e.key === 'Tab') trapFocus(e);
    });
  }
</script>


---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/Button.astro';
import TrustedBy from '../components/TrustedBy.astro';
import VideoCard from '../components/VideoCard.astro';

const isReelReady = false;

const navLinks = [
  { id: 'hero', label: 'Home', href: '#hero' },
  { id: 'about', label: 'About', href: '#about' },
  { id: 'cinematography', label: 'Cinematography', href: '#cinematography' },
  { id: 'contact', label: 'Contact', href: '#contact' },
];

const logos = [
  { name: 'HoneyBaked', src: '/logos/HoneyBaked.svg' },
  { name: 'Etihad', src: '/logos/Etihad.svg' },
  { name: 'Allstate', src: '/logos/Allstate.svg', width: 180 },
  { name: 'Kroger', src: '/logos/Kroger.svg' },
  { name: 'Georgia', src: '/logos/Georgia.svg', width: 200 },
  { name: 'OldSpice', src: '/logos/OldSpice.svg' },
  { name: 'Swiffer', src: '/logos/Swiffer.svg' },
  { name: 'Tide', src: '/logos/Tide.svg' },
  { name: 'PndG', src: '/logos/PndG.svg' },
];

const categories = [
  'All',
  'Commercial',
  'Interview',
  'Art',
  'Social',
  'Narrative',
];

// TODO: Replace each youtubeId with the real YouTube video ID after upload
// Format: 11-character ID from youtube.com/watch?v=XXXXXXXXXXX
const videos = [
  {
    id: 'v1',
    title: '8th Insignia',
    category: 'Art',
    youtubeId: 'PLACEHOLDER_V1',
    meta: '1080p • ANAMORPHIC • 2026',
  },
  {
    id: 'v2',
    title: 'STUDIO SESSION FINAL V2',
    category: 'Art',
    youtubeId: 'PLACEHOLDER_V2',
    meta: '1080p • SPHERICAL • 2024',
  },
  {
    id: 'v3',
    title: 'Resurgens Orthopedics: Adonis',
    category: 'Commercial',
    youtubeId: 'PLACEHOLDER_V3',
    meta: '1080p • ANAMORPHIC • 2023',
  },
  {
    id: 'v4',
    title: 'Resurgens Orthopedics: Loren',
    category: 'Commercial',
    youtubeId: 'PLACEHOLDER_V4',
    meta: '1080p • SPHERICAL • 2024',
  },
  {
    id: 'v5',
    title: 'ESnH',
    category: 'Interview',
    youtubeId: 'PLACEHOLDER_V5',
    meta: '1080p • ANAMORPHIC • 2023',
  },
  {
    id: 'v6',
    title: 'Resurgens Orthopedics: Spine Center',
    category: 'Interview',
    youtubeId: 'PLACEHOLDER_V6',
    meta: '1080p • SPHERICAL • 2024',
  },
  {
    id: 'v7',
    title: 'Atlanta Fanzone',
    category: 'Social',
    youtubeId: 'PLACEHOLDER_V7',
    meta: '1080p • ANAMORPHIC • 2026',
  },
  {
    id: 'v8',
    title: 'Camp Southern Ground: Land of Transformation',
    category: 'Narrative',
    youtubeId: 'PLACEHOLDER_V8',
    meta: '1080p • SPHERICAL • 2026',
  },
  {
    id: 'v9',
    title: 'Georgia Heart Video Campaign',
    category: 'Narrative',
    youtubeId: 'PLACEHOLDER_V9',
    meta: '1080p • ANAMORPHIC • 2026',
  },
  {
    id: 'v10',
    title: 'SPM',
    category: 'Social',
    youtubeId: 'PLACEHOLDER_V10',
    meta: '1080p • ANAMORPHIC • 2026',
  },
];

const INITIAL_VISIBLE = 4;
---

<Layout>
  <!-- ── Preloader ──────────────────────────────── -->
  <div
    id='preloader'
    aria-hidden='true'
    class='fixed inset-0 z-100 flex items-center justify-center'
    style='background: var(--color-surface-container-lowest);'>
    <h1
      class='font-display font-bold text-on-surface select-none'
      style='font-size: clamp(3rem, 10vw, 7rem); letter-spacing: -0.04em;'>
      Daniel Gualdron
    </h1>
  </div>

  <!-- ── Navigation ────────────────────────────── -->
  <Navbar links={navLinks} />

  <div id='page-wrap'>
    <main id='main-content'>
      <!-- ── Hero ─────────────────────────────────── -->
      <section
        id='hero'
        aria-label='Hero'
        class='relative min-h-screen flex flex-col justify-end pb-20 px-6 md:px-12 pt-32'
        style='background: var(--color-surface);'>
        <!-- Background portrait -->
        <img
          src='https://res.cloudinary.com/dqyaxyvxz/image/upload/f_auto,q_auto,w_1920/v1779308364/20250720-DaniShinobi-9_skz4wd.jpg'
          alt=''
          aria-hidden='true'
          width='1920'
          height='1080'
          loading='eager'
          fetchpriority='high'
          class='absolute inset-0 w-full h-full object-cover object-center'
          style='z-index: 0;'
        />
        <!-- Dark gradient overlay — keeps text legible -->
        <div
          class='absolute inset-0 pointer-events-none'
          style='z-index: 1; background: linear-gradient(to top, var(--color-surface) 20%, color-mix(in srgb, var(--color-surface) 50%, transparent) 55%, color-mix(in srgb, var(--color-surface) 20%, transparent) 100%);'
          aria-hidden='true'>
        </div>

        <div class='relative max-w-4xl' style='z-index: 2;'>
          <p
            class='text-xs uppercase tracking-widest mb-6'
            style='color: var(--color-primary); letter-spacing: 0.15em;'>
            Director of Photography
          </p>
          <h2
            class='font-display font-bold text-on-surface mb-8 leading-none'
            style='font-size: clamp(2.5rem, 7vw, 5.5rem); letter-spacing: -0.04em;'>
            Framing stories<br />worth watching.
          </h2>
          <div class='flex items-center gap-4 flex-wrap'>
            {
              isReelReady ? (
                <Button variant='primary' href='#reel' label='Watch the reel'>
                  Watch the Reel
                </Button>
              ) : (
                <Button variant='primary' disabled label='Reel coming soon'>
                  Reel Coming Soon
                </Button>
              )
            }
            <Button variant='secondary' href='#cinematography'>
              View Work
            </Button>
          </div>

          <!-- Scroll cue -->
          <div class='flex items-center gap-3 mt-6' aria-hidden='true'>
            <div class='w-8 h-px' style='background: var(--color-primary);'>
            </div>
            <span
              class='text-xs uppercase tracking-widest'
              style='color: var(--color-outline-variant); letter-spacing: 0.15em;'>
              Scroll to explore
            </span>
            <span
              class='text-on-surface-variant animate-bounce'
              style='animation-duration: 2s;'>↓</span
            >
          </div>
        </div>

        <!-- Trusted By -->
        <div
          class='relative mt-20'
          style='z-index: 2; border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 15%, transparent); padding-top: 2rem;'>
          <p
            class='text-xs uppercase tracking-widest mb-6 px-0'
            style='color: var(--color-outline-variant); letter-spacing: 0.15em;'>
            Trusted by
          </p>
          <TrustedBy logos={logos} />
        </div>
      </section>

      <!-- ── About ─────────────────────────────────── -->
      <section
        id='about'
        aria-label='About'
        class='px-6 md:px-12 py-24 md:py-32'
        style='background: var(--color-surface-container-low);'>
        <div
          class='max-w-6xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16 items-center'>
          <!-- Bio -->
          <div>
            <p
              class='text-xs uppercase tracking-widest mb-6'
              style='color: var(--color-primary); letter-spacing: 0.15em;'>
              About
            </p>
            <!-- Left accent bar + heading -->
            <div class='flex gap-4 items-stretch mb-6'>
              <span class='about-accent-bar' aria-hidden='true'></span>
              <h2
                class='font-display font-bold text-on-surface leading-tight'
                style='font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: -0.03em;'>
                Every frame is<br />a decision.
              </h2>
            </div>
            <p
              class='text-base leading-relaxed mb-4'
              style='color: var(--color-on-surface-variant);'>
              I believe stories aren't just seen, they're felt. As a filmmaker,
              editor, and creative originally from Colombia, based in Atlanta, I
              bridge the gap between imagination and high end production. For
              over seven years, I've specialized in crafting commercial,
              corporate, and branded content that blends cinematic atmosphere
              with authentic storytelling.
            </p>
            <p
              class='text-base leading-relaxed mb-8'
              style='color: var(--color-on-surface-variant);'>
              From concept development to the final edit, I immerse myself in
              every step of the process, cinematography, direction, and post
              production, turning bold ideas into striking visuals that
              resonate, inspire, and leave a lasting impact.
            </p>
          </div>

          <!-- Portrait -->
          <div class='relative'>
            <div
              class='relative rounded-lg overflow-hidden'
              style='background: var(--color-surface-container-high);'>
              <!-- Inner glow overlay -->
              <div
                class='absolute inset-0 z-10 rounded-lg pointer-events-none'
                style='box-shadow: inset 0 0 40px color-mix(in srgb, var(--color-surface-container-lowest) 30%, transparent);'
                aria-hidden='true'>
              </div>
              <img
                src='https://res.cloudinary.com/dqyaxyvxz/image/upload/f_auto,q_auto,w_900/v1779308186/ssf_Green_Rose-5_vcyvzk.heic'
                alt='Daniel Gualdron, Director of Photography'
                width='900'
                height='1125'
                loading='lazy'
                class='portrait-img w-full object-cover block'
                style='aspect-ratio: 4/5;'
              />
            </div>
          </div>
        </div>
      </section>

      <!-- ── Cinematography ─────────────────────────── -->
      <section
        id='cinematography'
        aria-label='Cinematography work'
        class='px-6 md:px-12 py-24 md:py-32'
        style='background: var(--color-surface);'>
        <div class='max-w-6xl mx-auto'>
          <div
            class='flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12'>
            <div>
              <p
                class='text-xs uppercase tracking-widest mb-3'
                style='color: var(--color-primary); letter-spacing: 0.15em;'>
                Work
              </p>
              <h2
                class='font-display font-bold text-on-surface leading-tight'
                style='font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em;'>
                Cinematography
              </h2>
            </div>

            <!-- Category filters -->
            <div
              role='group'
              aria-label='Filter by category'
              class='flex flex-wrap gap-2'
              id='filter-group'>
              {
                categories.map((cat, i) => (
                  <button
                    type='button'
                    class={`filter-pill text-xs uppercase tracking-widest px-4 py-2 rounded-full transition-all duration-300 cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary ${i === 0 ? 'active' : ''}`}
                    data-filter={cat}
                    aria-pressed={i === 0 ? 'true' : 'false'}
                    style={
                      i !== 0
                        ? `border: 1px solid color-mix(in srgb, var(--color-outline-variant) 20%, transparent); color: var(--color-on-surface-variant);`
                        : ''
                    }>
                    {cat}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Video grid -->
          <div
            id='video-grid'
            class='grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6'
            role='list'
            aria-label='Video portfolio'>
            {
              videos.map((v, i) => (
                <div role='listitem'>
                  <VideoCard
                    id={v.id}
                    title={v.title}
                    category={v.category}
                    youtubeId={v.youtubeId}
                    meta={v.meta}
                    hidden={i >= INITIAL_VISIBLE}
                  />
                </div>
              ))
            }
          </div>

          <!-- View All -->
          {
            videos.length > INITIAL_VISIBLE && (
              <div class='mt-10 text-center'>
                <Button
                  variant='secondary'
                  id='view-all-btn'
                  label='Show all cinematography work'>
                  View All Work
                </Button>
              </div>
            )
          }
        </div>
      </section>

      <!-- ── Contact ────────────────────────────────── -->
      <section
        id='contact'
        aria-label='Contact'
        class='relative px-6 md:px-12 py-24 md:py-32 overflow-hidden'
        style='background: var(--color-surface-container-lowest);'>
        <!-- Ambient glow -->
        <div class='contact-glow' aria-hidden='true'></div>

        <div class='relative z-10 max-w-2xl mx-auto text-center'>
          <p
            class='text-xs uppercase tracking-widest mb-6'
            style='color: var(--color-primary); letter-spacing: 0.15em;'>
            Get in touch
          </p>
          <h2
            class='font-display font-bold text-on-surface mb-6 leading-tight'
            style='font-size: clamp(2rem, 5vw, 3.5rem); letter-spacing: -0.04em;'>
            Let's make<br />something great.
          </h2>
          <p
            class='text-base leading-relaxed mb-10'
            style='color: var(--color-on-surface-variant);'>
            Available for commercial, narrative, and documentary projects. Reach
            out to discuss your vision.
          </p>

          <!-- Email CTA -->
          <Button
            variant='primary'
            href='mailto:gualdrondaniel@gmail.com'
            label='Email Daniel Gualdron'>
            Email Me
          </Button>

          <!-- Social links -->
          <div class='flex items-center justify-center gap-8 mt-12'>
            <a
              href='https://instagram.com'
              target='_blank'
              rel='noopener noreferrer'
              aria-label='Daniel Gualdron on Instagram (opens in new tab)'
              class='flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary'>
              <!-- Instagram icon -->
              <svg
                width='16'
                height='16'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.75'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'>
                <rect x='2' y='2' width='20' height='20' rx='5' ry='5'></rect>
                <circle cx='12' cy='12' r='4'></circle>
                <circle
                  cx='17.5'
                  cy='6.5'
                  r='1'
                  fill='currentColor'
                  stroke='none'></circle>
              </svg>
              Instagram
            </a>
            <div
              class='w-px h-4'
              style='background: var(--color-outline-variant);'
              aria-hidden='true'>
            </div>
            <a
              href='https://www.linkedin.com/in/daniel-gualdron-858063271'
              target='_blank'
              rel='noopener noreferrer'
              aria-label='Daniel Gualdron on LinkedIn (opens in new tab)'
              class='flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary'>
              <!-- LinkedIn icon -->
              <svg
                width='16'
                height='16'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.75'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'>
                <path
                  d='M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z'
                ></path>
                <rect x='2' y='9' width='4' height='12'></rect>
                <circle cx='4' cy='4' r='2'></circle>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>
      </section>
    </main>

    <!-- ── Footer ─────────────────────────────────── -->
    <footer
      id='site-footer'
      role='contentinfo'
      class='px-6 md:px-12 py-8 flex flex-col md:flex-row items-center justify-between gap-4'
      style='background: var(--color-surface-container-lowest); border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 10%, transparent);'>
      <p class='text-xs' style='color: var(--color-outline-variant);'>
        &copy; {new Date().getFullYear()} Daniel Gualdron. All rights reserved.
      </p>
      <p class='text-xs' style='color: var(--color-outline-variant);'>
        Director of Photography
      </p>
    </footer>
  </div>{/* #page-wrap */}

  <!-- ── Video Modal ──────────────────────────── -->
  <div
    id='video-modal'
    role='dialog'
    aria-modal='true'
    aria-label='Video player'
    class='fixed inset-0 z-80 hidden'>
    <!-- Backdrop -->
    <div
      id='modal-backdrop'
      class='absolute inset-0'
      style='background: rgba(4,4,4,0.9); opacity: 0;'>
    </div>

    <!-- Panel (this is what FLIP-animates) -->
    <div
      id='modal-inner'
      class='absolute rounded-lg overflow-hidden'
      style='top: 50%; left: 50%; width: min(90vw, 1100px); transform: translate(-50%, -50%); transform-origin: center center; opacity: 0;'>
      <!-- Close button -->
      <button
        id='modal-close'
        aria-label='Close video'
        class='absolute top-3 right-3 z-10 w-9 h-9 flex items-center justify-center rounded-full cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary'
        style='background: rgba(0,0,0,0.55); backdrop-filter: blur(6px); color: #fff; border: 1px solid rgba(255,255,255,0.12);'>
        <svg
          width='14'
          height='14'
          viewBox='0 0 14 14'
          fill='none'
          aria-hidden='true'>
          <path
            d='M1 1l12 12M13 1L1 13'
            stroke='currentColor'
            stroke-width='1.75'
            stroke-linecap='round'></path>
        </svg>
      </button>

      <!-- YouTube iframe container (iframe injected on open, destroyed on close) -->
      <div
        id='modal-player-container'
        class='w-full block'
        style='aspect-ratio: 16/9; background: #000;'>
      </div>

      <!-- Info bar -->
      <div
        class='px-5 py-4 flex items-baseline justify-between gap-4'
        style='background: var(--color-surface-container-lowest);'>
        <div>
          <p
            id='modal-category'
            class='text-xs uppercase tracking-widest mb-0.5'
            style='color: var(--color-primary); letter-spacing: 0.15em;'>
          </p>
          <h3
            id='modal-title'
            class='font-display text-base font-semibold text-on-surface leading-snug'>
          </h3>
        </div>
        <p
          id='modal-meta'
          class='text-xs shrink-0'
          style='color: var(--color-on-surface-variant);'>
        </p>
      </div>
    </div>
  </div>
</Layout>

<!-- ── Global modal styles ───────────────────────── -->
<style is:global>
  #page-wrap {
    transition: filter 0.35s ease;
  }
  #page-wrap.modal-open {
    filter: blur(5px) brightness(0.35);
    pointer-events: none;
    user-select: none;
  }
</style>

<!-- ── Scripts ───────────────────────────────────── -->
<script>
  const preloader = document.getElementById('preloader');
  const pageWrap = document.getElementById('page-wrap');
  const siteHeader = document.querySelector('body > header');

  if (preloader) {
    // Capture narrowed reference so setTimeout/event callbacks retain non-null type.
    const preloaderEl = preloader;
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;
    const preloaderHeadingEl = preloaderEl.querySelector('h1');

    if (preloaderHeadingEl) {
      if (prefersReducedMotion) {
        preloaderHeadingEl.animate([{ opacity: 0 }, { opacity: 1 }], {
          duration: 800,
          easing: 'ease-out',
          fill: 'forwards',
        });
      } else {
        preloaderHeadingEl.animate(
          [
            { opacity: 0, transform: 'translateY(80px) scale(0.85)' },
            { opacity: 1, transform: 'translateY(0px)  scale(1)' },
          ],
          { duration: 4000, easing: 'ease-in-out', fill: 'forwards' },
        );
      }
    }

    const preloaderHoldDelayMs = prefersReducedMotion ? 1000 : 5500;

    setTimeout(() => {
      preloaderEl.classList.add('done');

      setTimeout(
        () => {
          if (pageWrap) pageWrap.classList.add('revealed');
          if (siteHeader) siteHeader.classList.add('revealed');
        },
        prefersReducedMotion ? 0 : 900,
      );

      preloaderEl.addEventListener(
        'animationend',
        (e) => {
          if (e.animationName !== 'fadeOut') return;
          preloaderEl.remove();
        },
        { once: true },
      );
    }, preloaderHoldDelayMs);
  }

  const filterGroup = document.getElementById('filter-group');
  const videoGrid = document.getElementById('video-grid');
  const viewAllBtn = document.getElementById('view-all-btn');
  const INITIAL_VISIBLE_COUNT = 4;
  const INACTIVE_PILL_STYLE =
    'border: 1px solid color-mix(in srgb, var(--color-outline-variant) 20%, transparent); color: var(--color-on-surface-variant);';
  const FOCUSABLE_SELECTOR =
    'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

  let isGridExpanded = false;

  function cardMatchesFilter(card: HTMLElement, filter: string): boolean {
    return filter === 'All' || card.dataset.category === filter;
  }

  function getActiveFilter(): string {
    const activePillEl = filterGroup?.querySelector('.filter-pill.active');
    return (
      (activePillEl instanceof HTMLElement
        ? activePillEl.dataset.filter
        : null) ?? 'All'
    );
  }

  function collapseGrid(filter: string) {
    if (!videoGrid) return;
    let visibleCount = 0;
    videoGrid.querySelectorAll('.video-card').forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      if (cardMatchesFilter(card, filter)) {
        visibleCount++;
        card.dataset.hidden =
          visibleCount > INITIAL_VISIBLE_COUNT ? 'true' : 'false';
      }
    });
  }

  function syncViewAllButton(filter: string) {
    if (!viewAllBtn || !videoGrid) return;
    let matchCount = 0;
    videoGrid.querySelectorAll('.video-card').forEach((card) => {
      if (card instanceof HTMLElement && cardMatchesFilter(card, filter))
        matchCount++;
    });
    viewAllBtn.hidden = matchCount <= INITIAL_VISIBLE_COUNT;
    viewAllBtn.textContent = 'View All Work';
    viewAllBtn.setAttribute('aria-label', 'Show all cinematography work');
  }

  if (filterGroup && videoGrid) {
    // Capture narrowed references in block-scoped consts so closures
    // inherit the non-null type and TS doesn't re-widen them.
    const filterGroupEl = filterGroup;
    const videoGridEl = videoGrid;

    filterGroupEl.addEventListener('click', (e) => {
      if (!(e.target instanceof HTMLElement)) return;
      const clickedPill = e.target.closest('.filter-pill');
      if (!(clickedPill instanceof HTMLElement)) return;

      const selectedFilter = clickedPill.dataset.filter ?? 'All';

      filterGroupEl.querySelectorAll('.filter-pill').forEach((pill) => {
        const isActive = pill === clickedPill;
        pill.classList.toggle('active', isActive);
        pill.setAttribute('aria-pressed', String(isActive));
        if (pill instanceof HTMLElement) {
          pill.style.cssText = isActive ? '' : INACTIVE_PILL_STYLE;
        }
      });

      videoGridEl.querySelectorAll('.video-card').forEach((card) => {
        if (!(card instanceof HTMLElement)) return;
        card.dataset.hidden = cardMatchesFilter(card, selectedFilter)
          ? 'false'
          : 'true';
      });

      isGridExpanded = false;
      collapseGrid(selectedFilter);
      syncViewAllButton(selectedFilter);
    });
  }

  // View All / Show Less toggle
  if (viewAllBtn && videoGrid) {
    // Capture narrowed references so the click callback retains non-null types.
    const viewAllButtonEl = viewAllBtn;
    const videoGridEl = videoGrid;

    viewAllButtonEl.addEventListener('click', () => {
      const activeFilter = getActiveFilter();
      if (!isGridExpanded) {
        videoGridEl.querySelectorAll('.video-card').forEach((card) => {
          if (
            card instanceof HTMLElement &&
            cardMatchesFilter(card, activeFilter)
          ) {
            card.dataset.hidden = 'false';
          }
        });
        viewAllButtonEl.textContent = 'Show Less';
        viewAllButtonEl.setAttribute('aria-label', 'Show fewer videos');
        isGridExpanded = true;
      } else {
        collapseGrid(activeFilter);
        viewAllButtonEl.textContent = 'View All Work';
        viewAllButtonEl.setAttribute(
          'aria-label',
          'Show all cinematography work',
        );
        isGridExpanded = false;
      }
    });
  }

  // ── Video Modal ──────────────────────────────────────────────────────────
  const modal = document.getElementById('video-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const modalInner = document.getElementById('modal-inner');
  const playerContainer = document.getElementById('modal-player-container');
  const modalClose = document.getElementById('modal-close');
  const modalTitleEl = document.getElementById('modal-title');
  const modalMetaEl = document.getElementById('modal-meta');
  const modalCatEl = document.getElementById('modal-category');

  if (modal && backdrop && modalInner && playerContainer && modalClose) {
    // Capture narrowed references as block-scoped consts so named functions
    // and their inner callbacks retain non-null types.
    const modalEl = modal;
    const backdropEl = backdrop;
    const modalPanelEl = modalInner;
    const closeButtonEl = modalClose;
    const containerEl = playerContainer;

    let isModalOpen = false;
    let previouslyFocusedElement: Element | null = null;

    /** Build the YouTube embed URL with privacy-friendly defaults. */
    function buildYouTubeEmbedUrl(videoId: string): string {
      const params = new URLSearchParams({
        autoplay: '1',
        rel: '0',
        modestbranding: '1',
        playsinline: '1',
      });
      return `https://www.youtube.com/embed/${videoId}?${params.toString()}`;
    }

    /** Create and inject a YouTube IFrame into the container. */
    function injectYouTubeIframe(videoId: string, videoTitle: string): void {
      const iframe = document.createElement('iframe');
      iframe.src = buildYouTubeEmbedUrl(videoId);
      iframe.title = videoTitle;
      iframe.width = '100%';
      iframe.height = '100%';
      iframe.style.border = 'none';
      iframe.style.display = 'block';
      iframe.setAttribute(
        'allow',
        'autoplay; encrypted-media; picture-in-picture',
      );
      iframe.setAttribute('allowfullscreen', '');
      iframe.setAttribute('loading', 'lazy');
      containerEl.appendChild(iframe);
    }

    /** Remove the YouTube IFrame from the container to stop playback. */
    function destroyYouTubeIframe(): void {
      containerEl.innerHTML = '';
    }

    function openModal(detail: {
      youtubeId: string;
      title: string;
      meta: string;
      category: string;
      rect: DOMRect;
    }) {
      const { youtubeId, title, meta, category, rect } = detail;
      if (!youtubeId || isModalOpen) return;
      isModalOpen = true;
      previouslyFocusedElement = document.activeElement;

      if (modalTitleEl) modalTitleEl.textContent = title;
      if (modalMetaEl) modalMetaEl.textContent = meta;
      if (modalCatEl) modalCatEl.textContent = category;

      injectYouTubeIframe(youtubeId, title);

      modalEl.classList.remove('hidden');
      modalPanelEl.style.transition = 'none';
      modalPanelEl.style.transform = 'translate(-50%, -50%)';
      modalPanelEl.style.opacity = '0';
      backdropEl.style.transition = 'none';
      backdropEl.style.opacity = '0';
      modalEl.style.pointerEvents = 'none';

      void modalPanelEl.offsetHeight;
      const panelRect = modalPanelEl.getBoundingClientRect();

      const scaleX = rect.width / panelRect.width;
      const scaleY = rect.height / panelRect.height;
      const offsetX = rect.left + rect.width / 2 - window.innerWidth / 2;
      const offsetY = rect.top + rect.height / 2 - window.innerHeight / 2;

      modalPanelEl.style.transform = `translate(calc(-50% + ${offsetX}px), calc(-50% + ${offsetY}px)) scale(${scaleX}, ${scaleY})`;
      modalPanelEl.style.opacity = '1';

      document.body.style.overflow = 'hidden';
      pageWrap?.classList.add('modal-open');
      pageWrap?.setAttribute('inert', '');

      void modalPanelEl.offsetHeight;

      requestAnimationFrame(() => {
        modalPanelEl.style.transition =
          'transform 0.46s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease';
        modalPanelEl.style.transform = 'translate(-50%, -50%)';
        backdropEl.style.transition = 'opacity 0.35s ease';
        backdropEl.style.opacity = '1';
        modalEl.style.pointerEvents = 'auto';
      });

      setTimeout(() => closeButtonEl.focus(), 480);
    }

    function closeModal() {
      if (!isModalOpen) return;
      isModalOpen = false;
      modalEl.style.pointerEvents = 'none';

      modalPanelEl.style.transition =
        'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease';
      modalPanelEl.style.transform = 'translate(-50%, -50%) scale(0.94)';
      modalPanelEl.style.opacity = '0';
      backdropEl.style.transition = 'opacity 0.28s ease';
      backdropEl.style.opacity = '0';

      setTimeout(() => {
        modalEl.classList.add('hidden');
        destroyYouTubeIframe();
        document.body.style.overflow = '';
        pageWrap?.classList.remove('modal-open');
        pageWrap?.removeAttribute('inert');
        if (previouslyFocusedElement instanceof HTMLElement)
          previouslyFocusedElement.focus();
      }, 320);
    }

    function trapFocus(e: KeyboardEvent) {
      const focusableElements = Array.from(
        modalEl.querySelectorAll<HTMLElement>(FOCUSABLE_SELECTOR),
      ).filter((el) => !el.closest('[hidden]') && el.offsetParent !== null);

      if (focusableElements.length === 0) {
        e.preventDefault();
        return;
      }

      // Array is proven non-empty by the length guard above;
      // non-null assertions are safe and avoid redundant runtime checks.
      const firstFocusable = focusableElements[0]!;
      const lastFocusable = focusableElements[focusableElements.length - 1]!;

      if (e.shiftKey) {
        if (document.activeElement === firstFocusable) {
          e.preventDefault();
          lastFocusable.focus();
        }
      } else {
        if (document.activeElement === lastFocusable) {
          e.preventDefault();
          firstFocusable.focus();
        }
      }
    }

    document.addEventListener('video:open', (e) => {
      openModal(
        (
          e as CustomEvent<{
            youtubeId: string;
            title: string;
            meta: string;
            category: string;
            rect: DOMRect;
          }>
        ).detail,
      );
    });

    closeButtonEl.addEventListener('click', closeModal);

    modalEl.addEventListener('click', (e) => {
      if (!modalPanelEl.contains(e.target as Node | null)) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (!isModalOpen) return;
      if (e.key === 'Escape') {
        closeModal();
        return;
      }
      if (e.key === 'Tab') trapFocus(e);
    });
  }
</script>
